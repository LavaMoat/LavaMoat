{
  "additionalLocations": [
    {
      "location": ".",
      "modules": [
        "./pantspack.config.js"
      ]
    }
  ],
  "include": [
    "webpackish-app"
  ],
  "resources": {
    "pantspack": {
      "builtin": {
        "node:console.error": true,
        "node:console.log": true,
        "node:path.dirname": true,
        "node:path.join": true,
        "node:path.resolve": true,
        "node:util.parseArgs": true
      },
      "globals": {
        "__dirname": true
      },
      "packages": {
        "webpackish-app>jorts-folder": true,
        "pantspack-folder-runner": true,
        "webpackish-app": true
      }
    },
    "pantspack-folder-runner": {
      "packages": {
        "webpackish-app>jorts-folder": true
      }
    },
    "webpackish-app>jorts-folder": {
      "packages": {
        "webpackish-app": true
      }
    }
  },
  "root": {
    "usePolicy": "pantspack"
  }
}