{
  "name": "hello_world",
  "version": "0.0.0",
  "description": "Node.js Addons Example #1",
  "main": "linux-x64.js",
  "private": true,
  "dependencies": {
    "node-gyp-build": "4.8.0"
  },
  "scripts": {
    "install": "node-gyp-build",
    "build": "npm run build:darwin && npm run build:win32 && npm run build:linux && npm run build:linux-arm",
    "prebuildify": "npx prebuildify --napi --strip --target 20.19.0",
    "build:darwin": "npm run prebuildify -- --platform darwin --arch arm64",
    "build:win32": "npm run prebuildify -- --platform win32 --arch x64",
    "build:linux": "npm run prebuildify -- --platform linux --arch x64",
    "build:linux-arm": "npm run prebuildify -- --platform linux --arch arm64",
    "test:linux-x64": "node linux-x64.js",
    "test:darwin-arm64": "node darwin-arm64.js",
    "test:linux-arm64": "node linux-arm64.js",
    "test:win32": "node win32.js"
  },
  "gypfile": true,
  "devDependencies": {
    "prebuildify": "6.0.0"
  }

}
