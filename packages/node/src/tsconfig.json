{
  "compilerOptions": {
    "module": "NodeNext",
    "outDir": "../types",
    "paths": {
      "@lavamoat/types": ["../../types"],
      "lavamoat-core": ["../../core/types/src/types.d.ts"],
      "lavamoat-tofu/src/*.js": ["../../tofu/types/*.d.ts"],
      "@lavamoat/vog": ["../../vog/src/index.d.ts"],
      "@lavamoat/vog/*.js": ["../../vog/src/*.d.ts"]
    },
    "rootDir": ".",
    "strict": true,
    "stripInternal": true,
    "target": "esnext",
    "types": ["node", "ses"]
  },
  "extends": "../../../.config/tsconfig.src.json",
  "include": ["."],
  "references": [
    {
      "path": "../../core/tsconfig.json"
    },
    {
      "path": "../../types/tsconfig.json"
    },
    {
      "path": "../../tofu/tsconfig.json"
    },
    {
      "path": "../../vog/tsconfig.json"
    }
  ]
}
