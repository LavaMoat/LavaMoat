{
  "compilerOptions": {
    "module": "NodeNext",
    "outDir": "../types",
    "paths": {
      "@lavamoat/types": ["../../types"],
      "lavamoat-core": ["../../core/types/src/types.d.ts"],
      "lavamoat-tofu/src/inspectSource.js": [
        "../../tofu/types/inspectSource.d.ts"
      ],
      "lavamoat-tofu/src/inspectSesCompat.js": [
        "../../tofu/types/inspectSesCompat.d.ts"
      ]
    },
    "rootDir": ".",
    "strict": true,
    "stripInternal": true,
    "target": "esnext",
    "types": ["node", "ses"]
  },
  "extends": "../../../.config/tsconfig.src.json",
  "include": ["."],
  "references": [
    {
      "path": "../../core/tsconfig.json"
    },
    {
      "path": "../../types/tsconfig.json"
    },
    {
      "path": "../../tofu/tsconfig.json"
    }
  ]
}
