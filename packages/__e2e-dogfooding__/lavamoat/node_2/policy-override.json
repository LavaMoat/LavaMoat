{
  "include": ["babel-loader", "@babel/preset-env", "@babel/preset-react"],
  "resources": {
    "@babel/core": {
      "packages": {
        "@babel/preset-env": true,
        "@babel/preset-typescript": true,
        "@babel/preset-react": true
      }
    },
    "webpack>graceful-fs": {
      "globals": {
        "___graceful-fs_previous": "write",
        "___graceful-fs_queue": "write"
      }
    },
    "html-webpack-plugin": {
      "builtin": {
        "url": true
      }
    },
    "webpack>terser-webpack-plugin>jest-worker": {
      "packages": {
        "webpack>terser-webpack-plugin": true
      }
    },
    "webpack>loader-runner": {
      "packages": {
        "@lavamoat/webpack": true,
        "babel-loader": true,
        "html-webpack-plugin": true,
        "mini-css-extract-plugin": true
      }
    },
    "html-webpack-plugin>lodash": {
      "builtin": {
        "util": true
      }
    }
  }
}
