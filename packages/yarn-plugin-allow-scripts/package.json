{
  "name": "@lavamoat/yarn-plugin-allow-scripts",
  "version": "1.0.0",
  "description": "A Yarn plugin for running `@lavamoat/allow-scripts` after install",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LavaMoat/LavaMoat.git",
    "directory": "packages/yarn-plugin-allow-scripts"
  },
  "license": "MIT",
  "private": true,
  "engines": {
    "node": "^16.20.0 || ^18.0.0 || ^20.0.0 || ^22.0.0",
    "yarn": "^3.1.1 || ^4.3.1"
  },
  "main": "./src/index.ts",
  "scripts": {
    "build": "./scripts/build.sh",
    "rebuild": "npm run build",
    "test": "ava"
  },
  "peerDependencies": {
    "@lavamoat/allow-scripts": ">=3.0.4",
    "@lavamoat/preinstall-always-fail": "*",
    "@yarnpkg/cli": "^3.8.3 || ^4.3.1",
    "@yarnpkg/core": "4.1.1"
  },
  "dependencies": {
    "@lavamoat/allow-scripts": ">=3.0.4",
    "@lavamoat/preinstall-always-fail": "*"
  },
  "devDependencies": {
    "@septh/ts-run": "1.2.5",
    "@yarnpkg/builder": "4.1.1",
    "@yarnpkg/cli": "4.3.1",
    "@yarnpkg/core": "4.1.1",
    "@yarnpkg/shell": "4.0.2",
    "ava": "6.1.3"
  },
  "ava": {
    "files": [
      "test/*.spec.mts"
    ],
    "timeout": "30s",
    "extensions": {
      "ts": "module",
      "mts": "module",
      "cts": "commonjs"
    },
    "nodeArguments": [
      "--import=@septh/ts-run/register"
    ]
  }
}
